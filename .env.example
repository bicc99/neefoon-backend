# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/neefoon

FIRMS_MAP_KEY=
CUSENSE_API_KEY=
MARKER_ASSETS_DIR=./assets/aqi-markers

LOCATIONIQ_API_KEY=

# Server-side secret used to mint and verify signed URLs (HMAC-SHA256).
# Used for resources fetched by clients that cannot set request headers —
# specifically MapLibre's ImageSource fetching the FIRMS hotspot PNG.
# Must stay server-side only — never bundle into the mobile app.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
URL_SIGNING_SECRET=

# Network interface to bind to. Defaults to 0.0.0.0 (all interfaces).
# Set to a specific IP (e.g. 192.168.0.8) to bind only on that interface during local development.
HOST=0.0.0.0

# Stripe secret key — use sk_test_... for development, sk_live_... for production.
# Find it at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# The public URL of the website frontend.
# Stripe redirects users here after payment succeeds or is cancelled.
# Local dev: http://localhost:5173 — Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# Secret used to sign/verify JWTs issued by the backend.
JWT_SECRET=<64+ random bytes, base64 or hex>

# iOS app identifiers used for App Attest / native builds.
IOS_BUNDLE_IDENTIFIER=com.yourappname.app
IOS_TEAM_IDENTIFIER=<your 10-char Apple Team ID>

# Android package name used for Play Integrity / native builds.
ANDROID_PACKAGE_NAME=com.yourappname.app

# --- Play Integrity service account credentials ---
# Two ways to provide credentials, pick the one that fits your environment:
#
# 1. Local dev: point GOOGLE_APPLICATION_CREDENTIALS at a JSON file on disk.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/play-integrity-service-account.json
#
# 2. Railway / containers: base64-encode the JSON and put it here. At boot,
#    src/lib/bootSecrets.ts decodes it to /tmp and sets
#    GOOGLE_APPLICATION_CREDENTIALS automatically. Leave unset if using #1.
#    Encode with: base64 -i play-integrity-service-account.json | tr -d '\n'
PLAY_INTEGRITY_KEY_B64=

