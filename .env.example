# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/neefoon

FIRMS_MAP_KEY=
CUSENSE_API_KEY=
MARKER_ASSETS_DIR=./assets/aqi-markers

LOCATIONIQ_API_KEY=

# Shared secret for all API clients (Neefoon app, admin tools).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# Network interface to bind to. Defaults to 0.0.0.0 (all interfaces).
# Set to a specific IP (e.g. 192.168.0.8) to bind only on that interface during local development.
HOST=0.0.0.0

# Stripe secret key — use sk_test_... for development, sk_live_... for production.
# Find it at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# The public URL of the website frontend.
# Stripe redirects users here after payment succeeds or is cancelled.
# Local dev: http://localhost:5173 — Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

